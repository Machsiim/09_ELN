# Database Configuration
DB_USER=elnuser
DB_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET=your_base64_encoded_secret_key_here_min_64_chars

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# Environment (Development, Production)
ASPNETCORE_ENVIRONMENT=Production

# Admin login credentials (works in all environments)
ELN_ADMIN_USERNAME=admin
ELN_ADMIN_PASSWORD=change_me_in_production

# Dev-only admin login fallback (only active when ASPNETCORE_ENVIRONMENT=Development)
ELN_DEV_ADMIN_PASSWORD=change_me_locally
